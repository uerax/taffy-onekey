{
    "inbounds": [
        {
            "listen": "0.0.0.0",
            "port": "${port}",
            "tag": "${port}",
            "protocol": "vless",
            "key": "${pubicKey}",
            "settings": {
                "clients": [
                    {
                        "id": "${password}",
                        "flow": ""
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "h2",
                "security": "reality",
                "realitySettings": {
                    "dest": "${reality_sni}:443",
                    "serverNames": [
                        "${reality_sni}"
                    ],
                    "privateKey": "${privateKey}",
                    "shortIds": [
                        "8eb7bab5a41eb27d",
                        ""
                    ]
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ]
            }
        }
    ]
}