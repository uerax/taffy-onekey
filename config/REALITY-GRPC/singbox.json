{
    "route": {      
    },
    "inbounds": [
        {
            "type": "vless",
            "listen": "::",
            "listen_port": 114514,
            "users": [
                {
                    "name": "${pubicKey}",
                    "uuid": "${password}",
                    "flow": ""
                }
            ],
            "tls": {
                "enabled": true,
                "server_name": "${reality_sni}",
                "reality": {
                    "enabled": true,
                    "handshake": {
                        "server": "${reality_sni}",
                        "server_port": 443
                    },
                    "private_key": "${privateKey}",
                    "short_id": [
                        "${shortId}",
                        ""
                    ]
                }
            },
            "transport": {
                "type": "grpc",
                "service_name": "${ws_path}"
            }
        }
    ],
    "outbounds": [
        {
            "type": "direct"
        }
    ]
}